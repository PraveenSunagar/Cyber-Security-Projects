import os

FILE_NAME = "passwords.txt"


def save_password():
    website = input("Website: ")
    username = input("Username: ")
    password = input("Password: ")

    with open(FILE_NAME, "a") as file:
        file.write(f"{website}|{username}|{password}\n")

    print("\n✅ Password Saved Successfully!\n")


def view_passwords():
    if not os.path.exists(FILE_NAME):
        print("\nNo passwords saved.\n")
        return

    print("\n====== SAVED PASSWORDS ======")

    with open(FILE_NAME, "r") as file:
        for line in file:
            website, username, password = line.strip().split("|")
            print(f"Website : {website}")
            print(f"Username: {username}")
            print(f"Password: {password}")
            print("-" * 30)


def search_password():
    if not os.path.exists(FILE_NAME):
        print("\nNo passwords found.\n")
        return

    website = input("Enter Website Name: ")

    found = False

    with open(FILE_NAME, "r") as file:
        for line in file:
            data = line.strip().split("|")

            if data[0].lower() == website.lower():
                print("\nRecord Found")
                print("Website :", data[0])
                print("Username:", data[1])
                print("Password:", data[2])
                found = True

    if not found:
        print("❌ Record Not Found")


def delete_password():
    if not os.path.exists(FILE_NAME):
        print("\nNo passwords found.\n")
        return

    website = input("Enter Website Name to Delete: ")

    records = []
    deleted = False

    with open(FILE_NAME, "r") as file:
        for line in file:
            data = line.strip().split("|")

            if data[0].lower() != website.lower():
                records.append(line)
            else:
                deleted = True

    with open(FILE_NAME, "w") as file:
        file.writelines(records)

    if deleted:
        print("✅ Record Deleted")
    else:
        print("❌ Record Not Found")


while True:

    print("\n===== PASSWORD MANAGER =====")
    print("1. Save Password")
    print("2. View Passwords")
    print("3. Search Password")
    print("4. Delete Password")
    print("5. Exit")

    choice = input("Enter Choice: ")

    if choice == "1":
        save_password()

    elif choice == "2":
        view_passwords()

    elif choice == "3":
        search_password()

    elif choice == "4":
        delete_password()

    elif choice == "5":
        print("Goodbye!")
        break

    else:
        print("Invalid Choice")
