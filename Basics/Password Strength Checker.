import re

print("=" * 40)
print("     PASSWORD STRENGTH CHECKER")
print("=" * 40)

password = input("Enter your password: ")

score = 0

#  Check
if len(password) >= 8:
    print("✅ Length: Good")
    score += 1
else:
    print("❌ Length: Minimum 8 characters required")

# Uppercase Check
if re.search(r"[A-Z]", password):
    print("✅ Uppercase Letter: Present")
    score += 1
else:
    print("❌ Uppercase Letter: Missing")

# Lowercase Check
if re.search(r"[a-z]", password):
    print("✅ Lowercase Letter: Present")
    score += 1
else:
    print("❌ Lowercase Letter: Missing")

# Number Check
if re.search(r"\d", password):
    print("✅ Number: Present")
    score += 1
else:
    print("❌ Number: Missing")

# Special Character Check
if re.search(r"[!@#$%^&*(),.?\":{}|<>]", password):
    print("✅ Special Character: Present")
    score += 1
else:
    print("❌ Special Character: Missing")

print("\n" + "=" * 40)

if score == 5:
    print("🟢 Password Strength: STRONG")
elif score >= 3:
    print("🟡 Password Strength: MEDIUM")
else:
    print("🔴 Password Strength: WEAK")

print("=" * 40)
